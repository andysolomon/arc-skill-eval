{
  "name": "arc-skill-eval",
  "version": "0.1.0",
  "description": "Pi-native framework and CLI for evaluating skills that ship adjacent SKILL.md and skill.eval.ts files.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andysolomon/arc-skill-eval.git"
  },
  "homepage": "https://github.com/andysolomon/arc-skill-eval",
  "bugs": {
    "url": "https://github.com/andysolomon/arc-skill-eval/issues"
  },
  "keywords": [
    "pi",
    "skills",
    "evaluation",
    "semantic-release",
    "typescript"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",

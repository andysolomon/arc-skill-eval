    "@semantic-release/npm": "^12.0.2",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/node": "^22.19.17",
    "conventional-changelog-conventionalcommits": "^9.1.0",
    "semantic-release": "^24.2.3"
  },
  "dependencies": {
    "typescript": "^5.9.3"
  }
}
